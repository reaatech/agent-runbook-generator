# LLM Provider Configuration
# Choose one provider and set its API key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# Google (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Default LLM provider (claude, openai, gemini, mock)
LLM_PROVIDER=claude

# Default model (optional, uses provider default if not set)
LLM_MODEL=

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agent-runbook-generator
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0

# MCP Server Configuration
MCP_SERVER_PORT=3000
# Bind to all interfaces (use 127.0.0.1 for local-only access)
MCP_SERVER_HOST=0.0.0.0

# Rate Limiting (requests per minute)
RATE_LIMIT_ANALYZE=30
RATE_LIMIT_GENERATE=10
RATE_LIMIT_VALIDATE=30

# Analysis Configuration
MAX_FILES_ANALYZED=10000
ANALYSIS_DEPTH=5
ANALYZER_TIMEOUT_MS=60000

# Default SLO Targets
DEFAULT_SLO_AVAILABILITY=99.9
DEFAULT_SLO_LATENCY_MS=500

# Output Configuration
OUTPUT_FORMAT=markdown
INCLUDE_TOC=true
INCLUDE_CROSS_REFS=true

# Logging
LOG_LEVEL=info
